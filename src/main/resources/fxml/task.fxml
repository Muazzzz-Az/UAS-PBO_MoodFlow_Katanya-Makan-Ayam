<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.kelompok.moodflow.controller.TaskController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="✅ Task Manager" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #6C63FF;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="addTaskBtn" text="+ New Task" style="-fx-background-color: #6C63FF; -fx-text-fill: white; -fx-background-radius: 20;" />
    </HBox>

    <VBox fx:id="taskForm" visible="false" managed="false" spacing="15"
          style="-fx-background-color: #F5F5F5; -fx-padding: 20; -fx-border-radius: 10;">
        <Label text="Add New Task" style="-fx-font-weight: bold; -fx-font-size: 16;" />
        <TextField fx:id="titleField" promptText="Task Title" />
        <TextArea fx:id="descriptionField" promptText="Description" prefHeight="80" />
        <DatePicker fx:id="dueDatePicker" promptText="Due Date" />
        <ComboBox fx:id="priorityCombo" promptText="Priority">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="HIGH" />
                    <String fx:value="MEDIUM" />
                    <String fx:value="LOW" />
                </FXCollections>
            </items>
        </ComboBox>
        <HBox spacing="10">
            <Button fx:id="saveTaskBtn" text="Save" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
            <Button fx:id="cancelTaskBtn" text="Cancel" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
        </HBox>
    </VBox>

    <HBox spacing="10">
        <Button fx:id="markDoneBtn" text="✔️ Tandai Selesai &amp; Lapor Mood" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" />
        <Button fx:id="deleteTaskBtn" text="🗑️ Hapus Tugas" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
    </HBox>

    <ListView fx:id="taskListView" prefHeight="400" />
</VBox>