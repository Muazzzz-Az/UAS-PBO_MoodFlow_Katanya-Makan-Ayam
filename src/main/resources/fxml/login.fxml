<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            style="-fx-background-color: linear-gradient(to bottom right, #6C63FF, #3F3D9E);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kelompok.moodflow.controller.LoginController">

    <children>
        <!-- Card Container -->
        <VBox alignment="CENTER" layoutX="250.0" layoutY="150.0"
              prefHeight="350.0" prefWidth="300.0"
              style="-fx-background-color: white; -fx-background-radius: 20;">

            <padding>
                <Insets bottom="30" left="30" right="30" top="30" />
            </padding>

            <children>
                <Label text="🌊 MoodFlow" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #6C63FF;">
                    <VBox.margin>
                        <Insets bottom="10" />
                    </VBox.margin>
                </Label>

                <Label text="Productivity meets Mood Tracking" style="-fx-font-size: 12; -fx-text-fill: #888;">
                    <VBox.margin>
                        <Insets bottom="30" />
                    </VBox.margin>
                </Label>

                <TextField fx:id="emailField" promptText="Email">
                    <VBox.margin>
                        <Insets bottom="15" />
                    </VBox.margin>
                </TextField>

                <PasswordField fx:id="passwordField" promptText="Password">
                    <VBox.margin>
                        <Insets bottom="25" />
                    </VBox.margin>
                </PasswordField>

                <Button fx:id="loginButton" text="LOGIN"
                        style="-fx-background-color: #6C63FF; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25;"
                        prefWidth="200" prefHeight="40">
                    <VBox.margin>
                        <Insets bottom="15" />
                    </VBox.margin>
                </Button>

                <HBox alignment="CENTER" spacing="10">
                    <Label text="Don't have an account?" style="-fx-text-fill: #888;" />
                    <Hyperlink fx:id="registerLink" text="Sign Up" style="-fx-text-fill: #6C63FF;" />
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>